---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header class="cosmic-header">
	<nav class="cosmic-nav">
		<div class="logo-section">
			<h2 class="cosmic-logo">
				<a href="/" class="logo-link">
					<span class="logo-text">{SITE_TITLE}</span>
					<span class="logo-glow"></span>
				</a>
			</h2>
		</div>

		<div class="nav-section">
			<div class="internal-links">
				<HeaderLink href="/">Home</HeaderLink>
				<HeaderLink href="/blog">Blog</HeaderLink>
				<HeaderLink href="/about">About</HeaderLink>
			</div>

			<div class="social-links">
				<a href="https://m.webtoo.ls/@astro" target="_blank" class="social-link">
					<span class="sr-only">Follow Astro on Mastodon</span>
					<svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24">
						<path fill="currentColor" d="M11.19 12.195c2.016-.24 3.77-1.475 3.99-2.603.348-1.778.32-4.339.32-4.339 0-3.47-2.286-4.488-2.286-4.488C12.062.238 10.083.017 8.027 0h-.05C5.92.017 3.942.238 2.79.765c0 0-2.285 1.017-2.285 4.488l-.002.662c-.004.64-.007 1.35.011 2.091.083 3.394.626 6.74 3.78 7.57 1.454.383 2.703.463 3.709.408 1.823-.1 2.847-.647 2.847-.647l-.06-1.317s-1.303.41-2.767.36c-1.45-.05-2.98-.156-3.215-1.928a3.614 3.614 0 0 1-.033-.496s1.424.346 3.228.428c1.103.05 2.137-.064 3.188-.189zm1.613-2.47H11.13v-4.08c0-.859-.364-1.295-1.091-1.295-.804 0-1.207.517-1.207 1.541v2.233H7.168V5.89c0-1.024-.403-1.541-1.207-1.541-.727 0-1.091.436-1.091 1.296v4.079H3.197V5.522c0-.859.22-1.541.66-2.046.456-.505 1.052-.764 1.793-.764.856 0 1.504.328 1.933.983L8 4.39l.417-.695c.429-.655 1.077-.983 1.934-.983.74 0 1.336.259 1.791.764.442.505.661 1.187.661 2.046v4.203z"/>
					</svg>
				</a>
				<a href="https://twitter.com/astrodotbuild" target="_blank" class="social-link">
					<span class="sr-only">Follow Astro on Twitter</span>
					<svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24">
						<path fill="currentColor" d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"/>
					</svg>
				</a>
				<a href="https://github.com/withastro/astro" target="_blank" class="social-link">
					<span class="sr-only">Go to Astro's GitHub repo</span>
					<svg viewBox="0 0 16 16" aria-hidden="true" width="24" height="24">
						<path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
					</svg>
				</a>
			</div>
		</div>

		<!-- Mobile Menu Toggle -->
		<button class="mobile-menu-toggle" aria-label="Toggle navigation menu">
			<span class="hamburger-line"></span>
			<span class="hamburger-line"></span>
			<span class="hamburger-line"></span>
		</button>
	</nav>

	<script>
		// Header scroll effects
		const header = document.querySelector('.cosmic-header');
		let lastScrollY = window.scrollY;

		window.addEventListener('scroll', () => {
			const currentScrollY = window.scrollY;

			if (currentScrollY > 50) {
				header.classList.add('scrolled');
			} else {
				header.classList.remove('scrolled');
			}

			lastScrollY = currentScrollY;
		});

		// Mobile menu toggle
		const mobileToggle = document.querySelector('.mobile-menu-toggle');
		const navSection = document.querySelector('.nav-section');

		if (mobileToggle && navSection) {
			mobileToggle.addEventListener('click', () => {
				navSection.classList.toggle('mobile-open');
				mobileToggle.classList.toggle('active');
			});
		}

		// Close mobile menu when clicking outside
		document.addEventListener('click', (e) => {
			if (!header.contains(e.target) && navSection?.classList.contains('mobile-open')) {
				navSection.classList.remove('mobile-open');
				mobileToggle?.classList.remove('active');
			}
		});
	</script>
</header>
<style>
	.cosmic-header {
		position: fixed;
		top: 0;
		left: 0;
		right: 0;
		z-index: 1000;
		background: rgba(10, 10, 26, 0.95);
		backdrop-filter: blur(20px);
		border-bottom: 1px solid var(--border);
		box-shadow: 0 4px 20px rgba(139, 92, 246, 0.3);
		transition: all 0.3s ease;
	}

	.cosmic-nav {
		max-width: 1200px;
		margin: 0 auto;
		padding: 0 2rem;
		display: flex;
		align-items: center;
		justify-content: space-between;
		min-height: 70px;
	}

	.logo-section {
		flex-shrink: 0;
	}

	.cosmic-logo {
		margin: 0;
		font-size: 1.5rem;
		font-weight: 700;
	}

	.logo-link {
		position: relative;
		text-decoration: none;
		color: var(--text-primary);
		display: flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.5rem 1rem;
		border-radius: 12px;
		transition: all 0.3s ease;
		text-shadow: 0 0 10px rgba(139, 92, 246, 0.5);
	}

	.logo-link:hover {
		background: rgba(139, 92, 246, 0.1);
		transform: translateY(-2px);
		text-shadow: 0 0 20px rgba(139, 92, 246, 0.8);
	}

	.logo-text {
		background: var(--gradient-primary);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
		font-size: 1.5rem;
		font-weight: 700;
	}

	.logo-glow {
		position: absolute;
		inset: 0;
		border-radius: 12px;
		background: var(--gradient-primary);
		opacity: 0;
		transition: opacity 0.3s ease;
		z-index: -1;
	}

	.logo-link:hover .logo-glow {
		opacity: 0.2;
	}

	.nav-section {
		display: flex;
		align-items: center;
		gap: 2rem;
	}

	.internal-links {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}

	.internal-links a {
		padding: 0.75rem 1rem;
		color: var(--text-secondary);
		border-bottom: 2px solid transparent;
		text-decoration: none;
		border-radius: 8px;
		transition: all 0.3s ease;
		font-weight: 500;
		position: relative;
	}

	.internal-links a:hover {
		color: var(--accent);
		background: rgba(139, 92, 246, 0.1);
		transform: translateY(-1px);
		text-shadow: 0 0 10px rgba(168, 85, 247, 0.5);
	}

	.internal-links a.active {
		color: var(--accent);
		border-bottom-color: var(--accent);
		background: rgba(139, 92, 246, 0.1);
		text-shadow: 0 0 15px rgba(168, 85, 247, 0.7);
	}

	.social-links {
		display: flex;
		align-items: center;
		gap: 1rem;
	}

	.social-link {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 40px;
		height: 40px;
		border-radius: 50%;
		background: rgba(139, 92, 246, 0.1);
		color: var(--text-muted);
		transition: all 0.3s ease;
		border: 1px solid transparent;
	}

	.social-link:hover {
		background: var(--gradient-primary);
		color: white;
		transform: translateY(-2px) scale(1.1);
		box-shadow: 0 8px 25px rgba(139, 92, 246, 0.4);
		border-color: var(--accent);
	}

	/* Mobile Menu Toggle */
	.mobile-menu-toggle {
		display: none;
		flex-direction: column;
		gap: 4px;
		background: none;
		border: none;
		cursor: pointer;
		padding: 0.5rem;
		border-radius: 6px;
		transition: all 0.3s ease;
	}

	.mobile-menu-toggle:hover {
		background: rgba(139, 92, 246, 0.1);
	}

	.hamburger-line {
		width: 24px;
		height: 2px;
		background: var(--text-primary);
		transition: all 0.3s ease;
		border-radius: 1px;
	}

	/* Responsive Design */
	@media (max-width: 768px) {
		.cosmic-nav {
			padding: 0 1rem;
		}

		.nav-section {
			display: none;
		}

		.mobile-menu-toggle {
			display: flex;
		}

		.cosmic-logo {
			font-size: 1.25rem;
		}

		.logo-text {
			font-size: 1.25rem;
		}
	}

	@media (max-width: 480px) {
		.cosmic-nav {
			padding: 0 0.5rem;
			min-height: 60px;
		}

		.cosmic-logo {
			font-size: 1.1rem;
		}

		.logo-text {
			font-size: 1.1rem;
		}
	}

	/* Scroll Effects */
	.cosmic-header.scrolled {
		background: rgba(10, 10, 26, 0.98);
		box-shadow: 0 8px 32px rgba(139, 92, 246, 0.4);
	}

	/* Animation for mobile menu */
	@media (max-width: 768px) {
		.nav-section.mobile-open {
			display: flex;
			position: absolute;
			top: 100%;
			left: 0;
			right: 0;
			background: rgba(10, 10, 26, 0.98);
			backdrop-filter: blur(20px);
			flex-direction: column;
			padding: 1rem;
			border-top: 1px solid var(--border);
			animation: slideDown 0.3s ease;
		}

		.internal-links {
			flex-direction: column;
			width: 100%;
		}

		.internal-links a {
			width: 100%;
			text-align: center;
			margin-bottom: 0.5rem;
		}

		/* Hamburger animation */
		.mobile-menu-toggle.active .hamburger-line:nth-child(1) {
			transform: rotate(45deg) translate(5px, 5px);
		}

		.mobile-menu-toggle.active .hamburger-line:nth-child(2) {
			opacity: 0;
		}

		.mobile-menu-toggle.active .hamburger-line:nth-child(3) {
			transform: rotate(-45deg) translate(7px, -6px);
		}
	}

	@keyframes slideDown {
		from {
			opacity: 0;
			transform: translateY(-10px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}
</style>
