---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';
import { blogApi, utils as pocketbaseUtils } from '../../lib/pocketbase';

// Get current language from URL params or default to English
const url = new URL(Astro.request.url);
const lang = (url.searchParams.get('lang') || 'en') as 'en' | 'it' | 'sl';

// Fetch posts from PocketBase
const response = await blogApi.getPublishedPosts({ language: lang });
const posts = response.items;
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead title={`${SITE_TITLE} - Blog`} description={SITE_DESCRIPTION} />
		<style>
			.hero {
				background: var(--gradient-secondary);
				padding: 4rem 2rem 2rem;
				text-align: center;
				color: var(--text-primary);
				position: relative;
				overflow: hidden;
			}

			.hero::before {
				content: '';
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				background:
					radial-gradient(circle at 20% 30%, rgba(139, 92, 246, 0.2) 0%, transparent 50%),
					radial-gradient(circle at 80% 70%, rgba(168, 85, 247, 0.15) 0%, transparent 50%);
				animation: nebula 15s ease-in-out infinite;
			}

			.hero-content {
				position: relative;
				z-index: 2;
				max-width: 1200px;
				margin: 0 auto;
			}

			.hero-title {
				font-size: 3rem;
				font-weight: 700;
				margin-bottom: 1rem;
				background: var(--gradient-primary);
				-webkit-background-clip: text;
				-webkit-text-fill-color: transparent;
				background-clip: text;
				text-shadow: 0 0 30px rgba(139, 92, 246, 0.5);
				animation: float 4s ease-in-out infinite;
			}

			.hero-subtitle {
				font-size: 1.25rem;
				color: var(--text-secondary);
				margin-bottom: 2rem;
				max-width: 600px;
				margin-left: auto;
				margin-right: auto;
				text-shadow: 0 0 10px rgba(255, 255, 255, 0.3);
			}

			.language-switcher {
				display: flex;
				justify-content: center;
				gap: 1rem;
				margin-bottom: 2rem;
			}

			.lang-btn {
				padding: 0.5rem 1rem;
				border: 1px solid var(--border);
				border-radius: 8px;
				background: var(--bg-tertiary);
				color: var(--text-primary);
				text-decoration: none;
				transition: all 0.2s ease;
			}

			.lang-btn.active {
				background: var(--gradient-primary);
				color: white;
				border-color: var(--primary);
			}

			.posts-section {
				padding: 2rem;
				max-width: 1200px;
				margin: 0 auto;
			}

			.posts-grid {
				display: grid;
				grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
				gap: 2rem;
				margin-top: 2rem;
			}

			.blog-card {
				background: rgba(26, 26, 58, 0.8);
				backdrop-filter: blur(15px);
				border: 1px solid var(--border);
				border-radius: 16px;
				padding: 1.5rem;
				transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
				text-decoration: none;
				color: inherit;
				display: block;
				position: relative;
				overflow: hidden;
				box-shadow: var(--box-shadow);
			}

			.blog-card::before {
				content: '';
				position: absolute;
				top: 0;
				left: -100%;
				width: 100%;
				height: 100%;
				background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.1), transparent);
				transition: left 0.5s ease;
			}

			.blog-card:hover::before {
				left: 100%;
			}

			.blog-card:hover {
				transform: translateY(-8px) scale(1.02);
				box-shadow: var(--glow);
				border-color: var(--accent);
				background: rgba(42, 27, 61, 0.9);
			}

			.post-image {
				width: 100%;
				height: 200px;
				background: var(--gradient-primary);
				border-radius: 8px;
				margin-bottom: 1rem;
				display: flex;
				align-items: center;
				justify-content: center;
				color: white;
				font-size: 1.5rem;
				font-weight: 700;
			}

			.post-title {
				color: var(--text-primary);
				font-size: 1.25rem;
				font-weight: 700;
				margin-bottom: 0.5rem;
				line-height: 1.3;
			}

			.post-description {
				color: var(--text-secondary);
				line-height: 1.6;
				margin-bottom: 1rem;
			}

			.post-meta {
				display: flex;
				justify-content: space-between;
				align-items: center;
				font-size: 0.9rem;
				color: var(--text-muted);
			}

			.post-language {
				background: var(--gradient-primary);
				color: white;
				padding: 0.25em 0.5em;
				border-radius: 8px;
				font-size: 0.8em;
				font-weight: 600;
				text-transform: uppercase;
				box-shadow: 0 2px 10px rgba(139, 92, 246, 0.3);
				transition: all 0.3s ease;
			}

			.post-language:hover {
				transform: scale(1.1);
				box-shadow: 0 4px 20px rgba(139, 92, 246, 0.5);
			}

			@keyframes nebula {
				0%, 100% { transform: scale(1) rotate(0deg); opacity: 0.6; }
				50% { transform: scale(1.1) rotate(180deg); opacity: 0.8; }
			}

			@keyframes float {
				0%, 100% { transform: translateY(0px) rotate(0deg); }
				33% { transform: translateY(-10px) rotate(1deg); }
				66% { transform: translateY(5px) rotate(-1deg); }
			}

			@media (max-width: 768px) {
				.hero {
					padding: 3rem 1rem 2rem;
				}

				.hero-title {
					font-size: 2.5rem;
				}

				.hero-subtitle {
					font-size: 1.1rem;
				}

				.posts-grid {
					grid-template-columns: 1fr;
					padding: 1rem;
				}
			}

			@media (max-width: 480px) {
				.hero-title {
					font-size: 2rem;
				}

				.posts-section {
					padding: 1rem;
				}
			}
		</style>
	</head>
	<body>
		<!-- Cosmic Space Particles -->
		<div class="cosmic-particles"></div>

		<!-- Add padding for fixed header -->
		<div style="padding-top: 70px;"></div>

		<a href="#main-content" class="skip-link sr-only">Skip to main content</a>
		<Header />

		<header class="hero">
			<div class="hero-content">
				<h1 class="hero-title">Blog Posts</h1>
				<p class="hero-subtitle">Explore our latest articles on AI ethics and human responsibility</p>

				<nav class="language-switcher" aria-label="Language selection">
					<a href="?lang=en" class:list={[ 'lang-btn', { active: lang === 'en' } ]} aria-current={lang === 'en' ? 'page' : undefined}>English</a>
					<a href="?lang=it" class:list={[ 'lang-btn', { active: lang === 'it' } ]} aria-current={lang === 'it' ? 'page' : undefined}>Italiano</a>
					<a href="?lang=sl" class:list={[ 'lang-btn', { active: lang === 'sl' } ]} aria-current={lang === 'sl' ? 'page' : undefined}>Slovenščina</a>
				</nav>
			</div>
		</header>

		<main id="main-content" class="posts-section">
			<section id="postsSection" class="posts-grid" aria-label="Blog posts" role="region">
				{posts.length === 0 ? (
					<div style="grid-column: 1 / -1; text-align: center; padding: 3rem; color: var(--text-muted);">
						<h3>No posts found</h3>
						<p>Check back later for new content.</p>
					</div>
				) : (
					posts.map(post => (
						<a href={`/blog/${post.slug}?lang=${lang}`} class="blog-card">
							<div class="post-image">
								📝
							</div>
							<h3 class="post-title">{post.title}</h3>
							<p class="post-description">{post.excerpt || 'Read more...'}</p>
							<div class="post-meta">
								<span class="post-language">{lang.toUpperCase()}</span>
								<span>{pocketbaseUtils.formatDate(post.publish_date || post.created)}</span>
							</div>
						</a>
					))
				)}
			</section>
		</main>

		<Footer />
	</body>
</html>
