---
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

// Get the slug from the URL
const { slug } = Astro.params;

// Get language from query params
const url = new URL(Astro.request.url);
const lang = url.searchParams.get('lang') || 'en';

// This would normally fetch from PocketBase, but for now we'll show a placeholder
const post = {
	title: 'Post not found',
	content: 'This post is not available yet.',
	description: 'Post not found',
	author: 'NoDaysIdle',
	publish_date: new Date().toISOString(),
	tags: [],
	lang: lang
};
---

<!doctype html>
<html lang={lang}>
	<head>
		<BaseHead
			title={`${post.title} | ${SITE_TITLE}`}
			description={post.description}
		/>
		<style>
			.post-container {
				min-height: 100vh;
				background: var(--gradient-secondary);
				padding: 2rem;
			}
			.post-card {
				background: var(--bg-card);
				border-radius: 12px;
				padding: 3rem;
				box-shadow: var(--box-shadow-lg);
				border: 1px solid var(--border);
				max-width: 800px;
				margin: 0 auto;
			}
			.post-header {
				margin-bottom: 2rem;
				text-align: center;
			}
			.post-title {
				color: var(--text-primary);
				font-size: 2.5rem;
				font-weight: 700;
				margin-bottom: 1rem;
				line-height: 1.2;
			}
			.post-meta {
				display: flex;
				justify-content: center;
				align-items: center;
				gap: 2rem;
				color: var(--text-muted);
				font-size: 0.9rem;
				margin-bottom: 1rem;
			}
			.post-description {
				color: var(--text-secondary);
				font-size: 1.1rem;
				line-height: 1.6;
				margin-bottom: 2rem;
				text-align: center;
			}
			.post-content {
				color: var(--text-primary);
				line-height: 1.8;
				font-size: 1.1rem;
			}
			.post-content h1,
			.post-content h2,
			.post-content h3,
			.post-content h4,
			.post-content h5,
			.post-content h6 {
				color: var(--text-primary);
				margin-top: 2rem;
				margin-bottom: 1rem;
				font-weight: 700;
			}
			.post-content p {
				margin-bottom: 1.5rem;
			}
			.post-content blockquote {
				border-left: 4px solid var(--accent);
				padding-left: 1rem;
				margin: 2rem 0;
				color: var(--text-secondary);
				font-style: italic;
			}
			.post-content code {
				background: var(--bg-tertiary);
				padding: 0.25rem 0.5rem;
				border-radius: 4px;
				font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
				font-size: 0.9em;
			}
			.post-content pre {
				background: var(--bg-tertiary);
				padding: 1rem;
				border-radius: 8px;
				overflow-x: auto;
				margin: 1.5rem 0;
			}
			.post-content pre code {
				background: none;
				padding: 0;
			}
			.language-switcher {
				display: flex;
				justify-content: center;
				gap: 1rem;
				margin-bottom: 2rem;
			}
			.lang-btn {
				padding: 0.5rem 1rem;
				border: 1px solid var(--border);
				border-radius: 8px;
				background: var(--bg-tertiary);
				color: var(--text-primary);
				text-decoration: none;
				transition: all 0.2s ease;
			}
			.lang-btn.active {
				background: var(--gradient-primary);
				color: white;
				border-color: var(--primary);
			}
			.tags-section {
				margin-top: 3rem;
				padding-top: 2rem;
				border-top: 1px solid var(--border);
			}
			.tags-label {
				color: var(--text-secondary);
				font-size: 0.9rem;
				margin-bottom: 0.5rem;
			}
			.tags-list {
				display: flex;
				flex-wrap: wrap;
				gap: 0.5rem;
			}
			.tag {
				background: var(--bg-tertiary);
				color: var(--text-secondary);
				padding: 0.25rem 0.75rem;
				border-radius: 20px;
				font-size: 0.8rem;
				text-decoration: none;
			}
			@media (max-width: 768px) {
				.post-card {
					padding: 1.5rem;
				}
				.post-title {
					font-size: 2rem;
				}
				.post-meta {
					flex-direction: column;
					gap: 0.5rem;
				}
				.language-switcher {
					flex-wrap: wrap;
				}
			}
		</style>
	</head>
	<body>
		<Header />
		<div class="post-container">
			<div class="post-card">
				<div class="language-switcher">
					<a href={`/blog/${slug}?lang=en`} class={`lang-btn ${lang === 'en' ? 'active' : ''}`}>English</a>
					<a href={`/blog/${slug}?lang=it`} class={`lang-btn ${lang === 'it' ? 'active' : ''}`}>Italiano</a>
					<a href={`/blog/${slug}?lang=sl`} class={`lang-btn ${lang === 'sl' ? 'active' : ''}`}>Slovenščina</a>
				</div>

				<header class="post-header">
					<h1 class="post-title">{post.title}</h1>
					<div class="post-meta">
						<span>By {post.author}</span>
						<span>{new Date(post.publish_date).toLocaleDateString()}</span>
						<span>{lang.toUpperCase()}</span>
					</div>
					<p class="post-description">{post.description}</p>
				</header>

				<div class="post-content">
					<!-- Post content will be rendered here -->
					<div id="postContent">
						Loading...
					</div>
				</div>

				{post.tags && post.tags.length > 0 && (
					<div class="tags-section">
						<div class="tags-label">Tags:</div>
						<div class="tags-list">
							{post.tags.map(tag => (
								<a href={`/?lang=${lang}&tag=${tag}`} class="tag">{tag}</a>
							))}
						</div>
					</div>
				)}
			</div>
		</div>
		<Footer />

		<script>
			import { blogApi } from '../../lib/pocketbase';

			const slug = '{slug}';
			const lang = '{lang}';
			const postContent = document.getElementById('postContent');

			// Load post content
			async function loadPost() {
				try {
					const post = await blogApi.getPostBySlug(slug, lang);

					if (post) {
						// Update page title
						document.title = `${post.title} | NoDaysIdle Blog`;

						// Render content
						postContent.innerHTML = post.content;

						// Update meta information
						const titleElement = document.querySelector('.post-title');
						const descriptionElement = document.querySelector('.post-description');

						if (titleElement) titleElement.textContent = post.title;
						if (descriptionElement) descriptionElement.textContent = post.description;
					} else {
						postContent.innerHTML = `
							<div style="text-align: center; padding: 3rem; color: var(--text-muted);">
								<h3>Post not found</h3>
								<p>The requested post could not be found.</p>
								<a href="/?lang=${lang}" style="color: var(--primary);">← Back to homepage</a>
							</div>
						`;
					}
				} catch (error) {
					console.error('Failed to load post:', error);
					postContent.innerHTML = `
						<div style="text-align: center; padding: 3rem; color: var(--text-muted);">
							<h3>Error loading post</h3>
							<p>Please try again later.</p>
							<a href="/?lang=${lang}" style="color: var(--primary);">← Back to homepage</a>
						</div>
					`;
				}
			}

			loadPost();
		</script>
	</body>
</html>